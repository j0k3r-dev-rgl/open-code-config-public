	"mcp": {
		"context7": {
			"enabled": true,
			"headers": {
				"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
			},
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"engram": {
			"command": [
				"/home/linuxbrew/.linuxbrew/bin/engram",
				"mcp",
				"--tools=agent"
			],
			"type": "local"
		},
		"metronous": {
			"command": [
				"/usr/local/bin/metronous",
				"mcp"
			],
			"type": "local"
		},
		"navigation-agent": {
			"command": [
				"npx",
				"-y",
				"@navigation-agent/mcp-server@latest"
			],
			"enabled": true,
			"type": "local"
		}
	},
	"permission": {
		"bash": {
			"*": "allow",
			"git commit *": "ask",
			"git push": "ask",
			"git push *": "ask",
			"git push --force *": "ask",
			"git rebase *": "ask",
			"git reset --hard *": "ask"
		},
		"read": {
			"*": "allow",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/credentials.json": "deny",
			"**/secrets/**": "deny",
			"*.env": "deny",
			"*.env.*": "deny"
		}
	},
	"plugin": [
		"opencode-claude-auth",
		"metronous-opencode",
		"opencode-gemini-auth@latest"
	]
}