    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "engram": {
      "type": "local",
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ]
    },
    "navigation-agent": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@navigation-agent/mcp-server@latest"
      ],
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    }
  }
