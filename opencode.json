	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true,
			"headers": {
				"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
			}
		},
		"engram": {
			"type": "local",
			"command": [
				"/home/linuxbrew/.linuxbrew/bin/engram",
				"mcp",
				"--tools=agent"
			]
		},
		"metronous": {
			"type": "local",
			"command": [
				"/usr/local/bin/metronous",
				"mcp"
			]
		},
		"navigation-agent": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@navigation-agent/mcp-server@latest"
			],
			"enabled": true
		}
	},
	"instructions": [
		"/home/j0k3r/.config/opencode/rules/*.md"
	],
	"permission": {
		"bash": {
			"*": "allow",
			"git commit *": "ask",
			"git push": "ask",
			"git push *": "ask",
			"git push --force *": "ask",
			"git rebase *": "ask",
			"git reset --hard *": "ask"
		},
		"read": {
			"*": "allow",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/credentials.json": "deny",
			"**/secrets/**": "deny",
			"*.env": "deny",
			"*.env.*": "deny"
		}
	}
