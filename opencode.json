{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "Pair-Programming": {
      "description": "Senior Architect mentor - helpful first, challenging when it matters",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./AGENTS.md}",
      "tools": {
        "api_test": true,
        "bash": true,
        "edit": true,
        "glob": true,
        "read": true,
        "webfetch": true,
        "write": true
      }
    },
    "sdd-apply": {
      "description": "Implement code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-apply.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-archive": {
      "description": "Archive completed change artifacts",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-archive.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "sdd-design": {
      "description": "Create technical design from proposals",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-design.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "sdd-explore": {
      "description": "Investigate codebase and think through ideas",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-explore.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "sdd-init": {
      "description": "Bootstrap SDD context and project configuration",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-init.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "sdd-java-apply": {
      "description": "Implement Java Spring Mongo code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-java-apply.md}",
      "tools": {
        "api_test": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-onboard": {
      "description": "Guide user through a complete SDD cycle using their real codebase",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./agents/sdd-onboard.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-orchestrator": {
      "description": "Agent Teams Orchestrator - coordinates sub-agents, never does work inline",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "task": {
          "*": "deny",
          "sdd-*": "allow"
        }
      },
      "prompt": "{file:./agents/sdd-orchestrator.md}",
      "tools": {
        "bash": true,
        "delegate": true,
        "delegation_list": true,
        "delegation_read": true,
        "edit": true,
        "engram_mem_context": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "engram_mem_session_summary": true,
        "glob": true,
        "read": true,
        "task": true,
        "write": true
      }
    },
    "sdd-propose": {
      "description": "Create change proposals from explorations",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-propose.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "sdd-react-router-7-apply": {
      "description": "Implement React Router 7 code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-react-router-7-apply.md}",
      "tools": {
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-spec": {
      "description": "Write detailed specifications from proposals",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-spec.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "sdd-tasks": {
      "description": "Break down specs and designs into implementation tasks",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-tasks.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "sdd-verify": {
      "description": "Validate implementation against specs",
      "hidden": true,
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/sdd-verify.md}",
      "tools": {
        "api_test": true,
        "bash": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "glob": true,
        "read": true,
        "write": true
      }
    }
  },
  "instructions": [
    "/home/j0k3r/.config/opencode/rules/*.md"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "/home/linuxbrew/.linuxbrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    },
    "metronous": {
      "command": [
        "/usr/local/bin/metronous",
        "mcp"
      ],
      "type": "local"
    },
    "navigation-agent": {
      "command": [
        "npx",
        "-y",
        "@navigation-agent/mcp-server@latest"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "plugin": [
    "opencode-claude-auth",
    "opencode-qwencode-auth",
    "metronous-opencode"
  ]
}
