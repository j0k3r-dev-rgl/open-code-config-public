	"mcp": {
		"context7": {
			"enabled": true,
			"headers": {
				"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
			},
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"engram": {
			"command": ["engram", "mcp", "--tools=agent"],
			"type": "local"
		},
		"navigation-agent": {
			"command": ["npx", "-y", "@navigation-agent/mcp-server"],
			"enabled": true,
			"type": "local"
		},
		"notion": {
			"type": "remote",
			"url": "https://mcp.notion.com/mcp"
		}
	},
	"permission": {
		"bash": {
			"*": "allow",
			"git commit *": "ask",
			"git push": "ask",
			"git push *": "ask",
			"git push --force *": "ask",
			"git rebase *": "ask",
			"git reset --hard *": "ask"
		},
		"read": {
			"*": "allow",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/credentials.json": "deny",
			"**/secrets/**": "deny",
			"*.env": "deny",
			"*.env.*": "deny"
		}
	},
	"plugin": ["opencode-gemini-auth"]
