{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "opencode-mask-j0k3r-dev-rgl",
	"version": "3.1.0",
	"description": "Arch Linux TUI mask for OpenCode — custom themes, ASCII art manager, legend and tagline editor",
	"type": "module",
	"exports": {
		"./tui": {
			"import": "./tui.tsx"
		}
	},
	"files": [
		"tui.tsx",
		"config.ts",
		"ascii-store.ts",
		"ascii-frames.ts",
		"components.tsx",
		"themes/*.json"
	],
	"engines": {
		"opencode": ">=1.3.13"
	},
	"peerDependencies": {
		"@opencode-ai/plugin": "*",
		"@opentui/core": "*",
		"@opentui/solid": "*",
		"solid-js": "*"
	},
	"keywords": [
		"opencode",
		"plugin",
		"theme",
		"arch-linux",
		"tui",
		"ascii"
	],
	"author": "j0k3r",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/j0k3r/opencode-mask.git"
	}
}
