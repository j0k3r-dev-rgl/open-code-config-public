{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "opencode-mask-j0k3r-dev-rgl",
	"version": "3.0.0",
	"description": "Arch Linux TUI mask for OpenCode — hot pink theme with prominent ASCII logo and j0k3r-dev-rgl@latest legend",
	"type": "module",
	"exports": {
		"./tui": {
			"import": "./tui.tsx",
			"config": {
				"enabled": true,
				"theme": "j0k3r-dev-rgl",
				"set_theme": true,
				"show_detected": true,
				"show_os": true,
				"show_providers": true,
				"show_sidebar": true
			}
		}
	},
	"files": [
		"tui.tsx",
		"config.ts",
		"detection.ts",
		"ascii-frames.ts",
		"components.tsx",
		"themes/j0k3r-dev-rgl.json"
	],
	"engines": {
		"opencode": ">=1.3.13"
	},
	"peerDependencies": {
		"@opencode-ai/plugin": "*",
		"@opentui/core": "*",
		"@opentui/solid": "*",
		"solid-js": "*"
	},
	"keywords": [
		"opencode",
		"plugin",
		"theme",
		"arch-linux",
		"tui",
		"ascii"
	],
	"author": "j0k3r",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/j0k3r/opencode-mask.git"
	}
}
