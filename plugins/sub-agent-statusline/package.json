{
  "name": "opencode-subagent-statusline",
  "version": "0.1.3",
  "description": "OpenCode plugin that exposes subagent session statusline state",
  "type": "module",
  "main": "./dist/tui.js",
  "types": "./dist/tui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./runtime": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsup --watch"
  },
  "keywords": [
    "opencode",
    "plugin",
    "statusline",
    "subagent"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "esbuild-plugin-solid": "^0.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
